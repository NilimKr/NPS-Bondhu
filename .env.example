# NPS Bondhu - Environment Variables
# Copy this file to .env and fill in your API keys

# Option 1: Groq API (Recommended - faster, generous free tier)
# Get your key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Google Gemini API (Fallback)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Note: You only need ONE of the above API keys
# The app will use Groq if available, otherwise falls back to Google Gemini

# HuggingFace Token (only needed when running scripts/upload_to_hf.py)
# Generate a new token at: https://huggingface.co/settings/tokens
# Required scope: write access to your Space repo
HF_TOKEN=your_huggingface_token_here
